{
    "actorSpecification": 1,
    "name": "trustpilot-reviews-scraper",
    "title": "Trustpilot Reviews Scraper - Ratings, Replies & Insights",
    "description": "Scrape Trustpilot company reviews, star ratings, TrustScores, reviewer details, dates, and company replies. No login or API key needed. Export to JSON, CSV, or Excel.",
    "version": "1.0",
    "categories": ["BUSINESS", "LEAD_GENERATION", "MARKETING"],
    "dockerfile": "Dockerfile",
    "input": "../INPUT_SCHEMA.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "views": {
                "reviews": {
                    "title": "Reviews",
                    "transformation": {
                        "fields": [
                            "reviewId",
                            "companyName",
                            "reviewerName",
                            "reviewerCountry",
                            "starRating",
                            "reviewTitle",
                            "reviewBody",
                            "dateOfExperience",
                            "reviewPostedDate",
                            "verifiedPurchase",
                            "usefulCount",
                            "companyReply",
                            "companyReplyDate",
                            "reviewUrl",
                            "scrapedAt"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "reviewId": { "label": "Review ID", "format": "text" },
                            "companyName": { "label": "Company", "format": "text" },
                            "reviewerName": { "label": "Reviewer", "format": "text" },
                            "reviewerCountry": { "label": "Country", "format": "text" },
                            "starRating": { "label": "Stars", "format": "number" },
                            "reviewTitle": { "label": "Title", "format": "text" },
                            "reviewBody": { "label": "Review", "format": "text" },
                            "dateOfExperience": { "label": "Experience Date", "format": "text" },
                            "reviewPostedDate": { "label": "Posted Date", "format": "text" },
                            "verifiedPurchase": { "label": "Verified", "format": "boolean" },
                            "usefulCount": { "label": "Useful", "format": "number" },
                            "companyReply": { "label": "Company Reply", "format": "text" },
                            "companyReplyDate": { "label": "Reply Date", "format": "text" },
                            "reviewUrl": { "label": "URL", "format": "link" },
                            "scrapedAt": { "label": "Scraped At", "format": "text" }
                        }
                    }
                },
                "companies": {
                    "title": "Companies",
                    "transformation": {
                        "fields": [
                            "companyName",
                            "domain",
                            "trustpilotUrl",
                            "overallTrustScore",
                            "starRating",
                            "totalReviewCount",
                            "fiveStarPercent",
                            "fourStarPercent",
                            "threeStarPercent",
                            "twoStarPercent",
                            "oneStarPercent",
                            "claimedStatus",
                            "category",
                            "websiteUrl",
                            "scrapedAt"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "companyName": { "label": "Company", "format": "text" },
                            "domain": { "label": "Domain", "format": "text" },
                            "trustpilotUrl": { "label": "Trustpilot URL", "format": "link" },
                            "overallTrustScore": { "label": "TrustScore", "format": "number" },
                            "starRating": { "label": "Stars", "format": "number" },
                            "totalReviewCount": { "label": "Total Reviews", "format": "number" },
                            "fiveStarPercent": { "label": "5 Star %", "format": "number" },
                            "fourStarPercent": { "label": "4 Star %", "format": "number" },
                            "threeStarPercent": { "label": "3 Star %", "format": "number" },
                            "twoStarPercent": { "label": "2 Star %", "format": "number" },
                            "oneStarPercent": { "label": "1 Star %", "format": "number" },
                            "claimedStatus": { "label": "Claimed", "format": "boolean" },
                            "category": { "label": "Category", "format": "text" },
                            "websiteUrl": { "label": "Website", "format": "link" },
                            "scrapedAt": { "label": "Scraped At", "format": "text" }
                        }
                    }
                }
            }
        }
    },
    "pricingInfo": {
        "pricingModel": "PAY_PER_EVENT",
        "pricingPerEvent": {
            "actorChargeEvents": {
                "review-scraped": {
                    "eventTitle": "Review Scraped",
                    "eventDescription": "Charged for each Trustpilot review successfully extracted and saved to the dataset.",
                    "eventPriceUsd": 0.0015
                }
            }
        }
    },
    "defaultRunOptions": {
        "build": "latest",
        "memoryMbytes": 2048,
        "timeoutSecs": 3600
    },
    "minMemoryMbytes": 1024,
    "maxMemoryMbytes": 4096
}
