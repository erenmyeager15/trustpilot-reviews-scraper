{
    "actorSpecification": 1,
    "name": "trustpilot-reviews-scraper",
    "title": "Trustpilot Reviews Scraper: Ratings & Replies",
    "description": "Scrape public Trustpilot company reviews, ratings, review text, dates, verification signals, company replies, and company-level TrustScore summaries.",
    "version": "1.0",
    "buildTag": "latest",
    "categories": ["BUSINESS", "MARKETING"],
    "dockerfile": "Dockerfile",
    "input": "../INPUT_SCHEMA.json",
    "readme": "../README.md",
    "output": "./output_schema.json",
    "exampleRunInput": {
        "body": "{\"companyNames\":[\"nike.com\"],\"companyUrls\":[],\"maxReviewsPerCompany\":1,\"sortBy\":\"most_recent\",\"filterByRating\":\"all\",\"verifiedOnly\":false,\"proxyConfiguration\":{\"useApifyProxy\":true,\"apifyProxyGroups\":[\"RESIDENTIAL\"]}}",
        "contentType": "application/json; charset=utf-8"
    },
    "storages": {
        "dataset": "./dataset_schema.json"
    },
    "pricingInfo": {
        "pricingModel": "PAY_PER_EVENT",
        "pricingPerEvent": {
            "actorChargeEvents": {
                "apify-actor-start": {
                    "eventTitle": "Actor Start",
                    "eventDescription": "Charged when the Actor starts running. Number of events charged depends on Actor memory (one event per GB, minimum one event).",
                    "eventPriceUsd": 0.00005,
                    "isPrimaryEvent": false,
                    "isOneTimeEvent": true
                },
                "review-scraped": {
                    "eventTitle": "Review Scraped",
                    "eventDescription": "Charged for each Trustpilot review successfully extracted and saved to the dataset.",
                    "eventPriceUsd": 0.0015,
                    "isPrimaryEvent": true,
                    "isOneTimeEvent": false
                }
            }
        }
    },
    "defaultRunOptions": {
        "build": "latest",
        "memoryMbytes": 2048,
        "timeoutSecs": 900
    },
    "minMemoryMbytes": 1024,
    "maxMemoryMbytes": 2048
}
