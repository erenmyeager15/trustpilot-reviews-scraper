{
    "actorSpecification": 1,
    "name": "trustpilot-reviews-scraper",
    "title": "Trustpilot Reviews Scraper - Ratings, Replies & Insights",
    "description": "Collect public Trustpilot company review data including ratings, TrustScores, review text, dates, verification signals, and company replies. Export to JSON, CSV, or Excel.",
    "version": "1.0",
    "categories": ["BUSINESS", "MARKETING"],
    "dockerfile": "Dockerfile",
    "input": "../INPUT_SCHEMA.json",
    "readme": "../README.md",
    "output": "./output_schema.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "views": {
                "reviews": {
                    "title": "Reviews",
                    "transformation": {
                        "fields": [
                            "reviewId",
                            "companyName",
                            "starRating",
                            "reviewTitle",
                            "reviewBody",
                            "dateOfExperience",
                            "reviewPostedDate",
                            "verifiedPurchase",
                            "usefulCount",
                            "companyReply",
                            "companyReplyDate",
                            "reviewUrl",
                            "scrapedAt"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "reviewId": { "label": "Review ID", "format": "text" },
                            "companyName": { "label": "Company", "format": "text" },
                            "starRating": { "label": "Stars", "format": "number" },
                            "reviewTitle": { "label": "Title", "format": "text" },
                            "reviewBody": { "label": "Review", "format": "text" },
                            "dateOfExperience": { "label": "Experience Date", "format": "text" },
                            "reviewPostedDate": { "label": "Posted Date", "format": "text" },
                            "verifiedPurchase": { "label": "Verified", "format": "boolean" },
                            "usefulCount": { "label": "Useful", "format": "number" },
                            "companyReply": { "label": "Company Reply", "format": "text" },
                            "companyReplyDate": { "label": "Reply Date", "format": "text" },
                            "reviewUrl": { "label": "URL", "format": "link" },
                            "scrapedAt": { "label": "Scraped At", "format": "text" }
                        }
                    }
                }
            }
        }
    },
    "pricingInfo": {
        "pricingModel": "PAY_PER_EVENT",
        "pricingPerEvent": {
            "actorChargeEvents": {
                "apify-actor-start": {
                    "eventTitle": "Actor start",
                    "eventDescription": "Charged when the run starts to cover browser anti-bot challenge handling and the proxy session. Number of events depends on memory (one per GB, minimum one).",
                    "eventPriceUsd": 0.0025,
                    "isPrimaryEvent": false,
                    "isOneTimeEvent": true
                },
                "review-scraped": {
                    "eventTitle": "Review Scraped",
                    "eventDescription": "Charged for each Trustpilot review successfully extracted and saved to the dataset.",
                    "eventPriceUsd": 0.00075,
                    "isPrimaryEvent": true,
                    "isOneTimeEvent": false
                }
            }
        }
    },
    "defaultRunOptions": {
        "build": "latest",
        "memoryMbytes": 2048,
        "timeoutSecs": 1800
    },
    "minMemoryMbytes": 1024,
    "maxMemoryMbytes": 4096
}
